{
  "_comment": "SysTest 生产环境配置文件",
  "_version": "1.0",
  "_updated": "2026-03-21",
  
  "test": {
    "default_device": "/dev/ufs0",
    "default_runtime": 60,
    "default_size": "1G",
    "cleanup_after_test": true,
    "flush_cache_after_test": true
  },
  
  "fio": {
    "default_ioengine": "sync",
    "default_direct": true,
    "default_numjobs": 1,
    "timeout_seconds": 300,
    "retries": 1,
    "retry_delay_seconds": 2
  },
  
  "thresholds": {
    "performance": {
      "seq_read_burst_001": {
        "metric": "bandwidth",
        "target": 2100,
        "unit": "MB/s",
        "tolerance": 0.05
      },
      "seq_write_burst_003": {
        "metric": "bandwidth",
        "target": 1650,
        "unit": "MB/s",
        "tolerance": 0.05
      },
      "rand_read_burst_005": {
        "metric": "iops",
        "target": 200000,
        "unit": "IOPS",
        "tolerance": 0.05
      },
      "rand_write_burst_007": {
        "metric": "iops",
        "target": 330000,
        "unit": "IOPS",
        "tolerance": 0.05
      },
      "mixed_rw_009": {
        "metric": "total_iops",
        "target": 150000,
        "unit": "IOPS",
        "tolerance": 0.05
      }
    }
  },
  
  "precondition": {
    "min_available_space_gb": 2.0,
    "check_fio_installed": true,
    "check_device_permission": true,
    "check_health_status": true,
    "fail_on_critical_warning": false
  },
  
  "logging": {
    "log_dir": "logs",
    "console_level": "INFO",
    "file_level": "DEBUG",
    "max_log_size_mb": 10,
    "backup_count": 5,
    "enable_json_format": false
  },
  
  "report": {
    "output_dir": "results",
    "formats": ["html", "json"],
    "include_metrics": true,
    "include_logs": true,
    "open_browser": false
  },
  
  "ci_cd": {
    "enabled": true,
    "fail_on_threshold_breach": true,
    "upload_artifacts": true,
    "artifact_retention_days": 30
  }
}
