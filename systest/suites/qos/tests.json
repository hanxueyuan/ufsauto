{
  "description": "QoS 测试套件 - 服务质量验证",
  "tests": [
    {
      "name": "t_qos_latency_percentile_001",
      "description": "延迟百分位测试",
      "type": "latency",
      "fio": {
        "rw": "randread",
        "bs": "4k",
        "iodepth": 32,
        "numjobs": 1,
        "runtime": 300,
        "time_based": true,
        "lat_percentiles": 1
      },
      "target": {
        "p50": 200,
        "p99": 1000,
        "p999": 5000,
        "p9999": 10000,
        "unit": "μs"
      }
    },
    {
      "name": "t_qos_latency_jitter_002",
      "description": "延迟抖动测试",
      "type": "latency",
      "fio": {
        "rw": "randread",
        "bs": "4k",
        "iodepth": 16,
        "numjobs": 4,
        "runtime": 300,
        "time_based": true,
        "lat_percentiles": 1
      },
      "target": {
        "stddev": 500,
        "unit": "μs"
      }
    }
  ]
}
