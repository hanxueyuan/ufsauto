{
  "description": "QoS 测试套件 - 服务质量验证",
  "tests": [
    {
      "name": "t_qos_LatencyPercentile_001",
      "description": "延迟百分位测试",
      "type": "latency",
      "purpose": "验证 UFS 设备的延迟百分位指标，评估设备在不同负载下的延迟表现，确保 p99.99 延迟<10ms，满足车规级实时性要求。",
      "precondition": {
        "system_env": {
          "os": "Debian 12, kernel 5.15.120",
          "cpu_memory": "8 核，16GB",
          "fio_version": "fio-3.33"
        },
        "device_info": {
          "path": "/dev/ufs0",
          "model": "UFS 3.1 128GB",
          "firmware": "v1.0.0",
          "capacity": "128GB",
          "available_space": "≥10GB"
        },
        "config": {
          "enable": [],
          "disable": ["省电模式"],
          "special": []
        },
        "lun_config": {
          "count": 4,
          "LUN0": "64GB 系统盘",
          "LUN1": "32GB 数据盘（测试目标）",
          "LUN2": "16GB 日志盘",
          "LUN3": "16GB 预留",
          "mapping": "LUN1→/dev/ufs0"
        },
        "health": {
          "smart": "正常",
          "remaining_life": "98%",
          "bad_blocks": 0,
          "temperature": "35℃（当前）/ 45℃（最高）",
          "error_count": "CRC 错误=0, 重传次数=0"
        },
        "verification": [
          "SMART 状态必须为正常",
          "可用空间必须≥10GB",
          "温度必须<70℃",
          "剩余寿命必须>90%"
        ]
      },
      "test_steps": [
        "使用 FIO 发起随机读测试",
        "配置参数：rw=randread, bs=4k, iodepth=32, numjobs=1, runtime=300, lat_percentiles=1",
        "FIO 持续随机读取 300 秒（5 分钟）",
        "收集延迟统计数据（p50/p99/p99.9/p99.99）"
      ],
      "postcondition": [
        "延迟统计数据已保存到 results/qos/目录",
        "生成延迟分布报告",
        "设备恢复到空闲状态（等待 5 秒）",
        "数据清理：无测试数据残留"
      ],
      "fio": {
        "rw": "randread",
        "bs": "4k",
        "iodepth": 32,
        "numjobs": 1,
        "runtime": 300,
        "time_based": true,
        "lat_percentiles": 1
      },
      "target": {
        "p50": 200,
        "p99": 1000,
        "p999": 5000,
        "p9999": 10000,
        "unit": "μs"
      },
      "acceptance_criteria": [
        "p50 < 200 μs",
        "p99 < 1,000 μs",
        "p99.9 < 5,000 μs",
        "p99.99 < 10,000 μs (10ms)"
      ],
      "notes": [
        "延迟测试需要较长时间（300 秒）以确保统计准确性",
        "系统负载会影响延迟结果，建议在空闲系统上测试",
        "p99.99 是关键指标，反映极端情况下的延迟表现",
        "如果延迟超标，检查系统负载和中断处理"
      ]
    },
    {
      "name": "t_qos_LatencyJitter_002",
      "description": "延迟抖动测试",
      "type": "latency",
      "purpose": "验证 UFS 设备的延迟抖动指标，评估设备延迟的稳定性，确保延迟标准差<500μs，满足车规级系统对延迟稳定性的要求。",
      "precondition": {
        "system_env": {
          "os": "Debian 12, kernel 5.15.120",
          "cpu_memory": "8 核，16GB",
          "fio_version": "fio-3.33"
        },
        "device_info": {
          "path": "/dev/ufs0",
          "model": "UFS 3.1 128GB",
          "firmware": "v1.0.0",
          "capacity": "128GB",
          "available_space": "≥10GB"
        },
        "config": {
          "enable": [],
          "disable": ["省电模式"],
          "special": []
        },
        "lun_config": {
          "count": 4,
          "LUN0": "64GB 系统盘",
          "LUN1": "32GB 数据盘（测试目标）",
          "LUN2": "16GB 日志盘",
          "LUN3": "16GB 预留",
          "mapping": "LUN1→/dev/ufs0"
        },
        "health": {
          "smart": "正常",
          "remaining_life": "98%",
          "bad_blocks": 0,
          "temperature": "35℃（当前）/ 45℃（最高）",
          "error_count": "CRC 错误=0, 重传次数=0"
        },
        "verification": [
          "SMART 状态必须为正常",
          "可用空间必须≥10GB",
          "温度必须<70℃",
          "剩余寿命必须>90%"
        ]
      },
      "test_steps": [
        "使用 FIO 发起随机读测试",
        "配置参数：rw=randread, bs=4k, iodepth=16, numjobs=4, runtime=300, lat_percentiles=1",
        "FIO 持续随机读取 300 秒（5 分钟），4 个并发线程",
        "收集延迟统计数据，计算标准差"
      ],
      "postcondition": [
        "延迟统计数据已保存到 results/qos/目录",
        "生成延迟抖动报告",
        "设备恢复到空闲状态（等待 5 秒）",
        "数据清理：无测试数据残留"
      ],
      "fio": {
        "rw": "randread",
        "bs": "4k",
        "iodepth": 16,
        "numjobs": 4,
        "runtime": 300,
        "time_based": true,
        "lat_percentiles": 1
      },
      "target": {
        "stddev": 500,
        "unit": "μs"
      },
      "acceptance_criteria": [
        "延迟标准差 < 500 μs"
      ],
      "notes": [
        "4 个并发线程模拟多任务场景",
        "队列深度 16 适中，平衡性能和资源",
        "延迟抖动反映设备稳定性，对实时系统至关重要",
        "如果抖动超标，检查系统负载和 GC 干扰"
      ]
    }
  ]
}
