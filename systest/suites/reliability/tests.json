{
  "description": "可靠性测试套件 - 长期稳定性验证",
  "tests": [
    {
      "name": "t_reliability_StabilityTest_001",
      "description": "长期稳定性测试",
      "type": "reliability",
      "purpose": "验证 UFS 设备在长时间（24 小时）连续工作下的稳定性，确保无数据错误、无性能衰减、无设备故障，满足车规级可靠性要求。",
      "precondition": {
        "system_env": {
          "os": "Debian 12, kernel 5.15.120",
          "cpu_memory": "8 核，16GB",
          "fio_version": "fio-3.33"
        },
        "device_info": {
          "path": "/dev/ufs0",
          "model": "UFS 3.1 128GB",
          "firmware": "v1.0.0",
          "capacity": "128GB",
          "available_space": "≥20GB"
        },
        "config": {
          "enable": [],
          "disable": ["自动休眠"],
          "special": ["IO 调度器设置为 none"]
        },
        "lun_config": {
          "count": 4,
          "LUN0": "64GB 系统盘",
          "LUN1": "32GB 数据盘（测试目标）",
          "LUN2": "16GB 日志盘",
          "LUN3": "16GB 预留",
          "mapping": "LUN1→/dev/ufs0"
        },
        "health": {
          "smart": "正常",
          "remaining_life": "98%",
          "bad_blocks": 0,
          "temperature": "35℃（当前）/ 45℃（最高）",
          "error_count": "CRC 错误=0, 重传次数=0"
        },
        "verification": [
          "SMART 状态必须为正常",
          "可用空间必须≥20GB",
          "温度必须<70℃",
          "剩余寿命必须>90%",
          "电源必须稳定（建议使用 UPS）",
          "散热条件良好（建议加散热片或风扇）"
        ]
      },
      "test_steps": [
        "启动 24 小时稳定性测试",
        "配置参数：rw=randrw, rwmixread=70, bs=4k, iodepth=32, numjobs=2, runtime=86400, verify=0",
        "每 5 分钟记录一次性能数据（带宽/IOPS/延迟/温度）",
        "监控错误计数（CRC 错误/重传次数/IO 错误）",
        "24 小时后停止测试，分析数据"
      ],
      "postcondition": [
        "测试结果保存到 results/reliability/目录",
        "配置恢复：恢复自动休眠功能，恢复 IO 调度器为默认值（如 mq-deadline）",
        "设备恢复到空闲状态（等待 10 秒）",
        "数据清理：删除测试生成的临时文件"
      ],
      "fio": {
        "rw": "randrw",
        "rwmixread": 70,
        "bs": "4k",
        "iodepth": 32,
        "numjobs": 2,
        "runtime": 86400,
        "time_based": true,
        "verify": 0
      },
      "target": {
        "duration": 86400,
        "unit": "seconds",
        "max_errors": 0,
        "max_performance_drop": 0.20
      },
      "acceptance_criteria": [
        "无 IO 错误（错误计数=0）",
        "性能衰减 < 20%（初始带宽 vs 最终带宽）",
        "设备温度 < 70℃（全程）",
        "无设备掉线或重启"
      ],
      "notes": [
        "24 小时测试时间长，确保电源稳定",
        "测试前备份重要数据（虽然不会破坏数据）",
        "建议定期检查设备温度",
        "如温度超过 70℃，暂停测试并改善散热",
        "测试过程中不要中断，否则需要重新开始"
      ]
    }
  ]
}
