{
  "description": "性能测试套件 - UFS 基础性能验证",
  "tests": [
    {
      "name": "t_performance_sequential_read_burst_001",
      "description": "顺序读带宽 (Burst)",
      "type": "bandwidth",
      "fio": {
        "rw": "read",
        "bs": "128k",
        "iodepth": 32,
        "numjobs": 1,
        "runtime": 60,
        "time_based": true
      },
      "target": {
        "value": 2100,
        "unit": "MB/s",
        "tolerance": 0.95
      }
    },
    {
      "name": "t_performance_sequential_read_sustained_002",
      "description": "顺序读带宽 (Sustained)",
      "type": "bandwidth",
      "fio": {
        "rw": "read",
        "bs": "128k",
        "iodepth": 32,
        "numjobs": 1,
        "runtime": 300,
        "time_based": true
      },
      "target": {
        "value": 1800,
        "unit": "MB/s",
        "tolerance": 0.95
      }
    },
    {
      "name": "t_performance_sequential_write_burst_003",
      "description": "顺序写带宽 (Burst)",
      "type": "bandwidth",
      "fio": {
        "rw": "write",
        "bs": "128k",
        "iodepth": 32,
        "numjobs": 1,
        "runtime": 60,
        "time_based": true
      },
      "target": {
        "value": 1650,
        "unit": "MB/s",
        "tolerance": 0.95
      }
    },
    {
      "name": "t_performance_sequential_write_sustained_004",
      "description": "顺序写带宽 (Sustained)",
      "type": "bandwidth",
      "fio": {
        "rw": "write",
        "bs": "128k",
        "iodepth": 32,
