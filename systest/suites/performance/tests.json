        "runtime": 300,
        "time_based": true
      },
      "target": {
        "value": 250,
        "unit": "MB/s",
        "tolerance": 0.95
      }
    },
    {
      "name": "t_performance_random_read_burst_005",
      "description": "随机读 IOPS (Burst)",
      "type": "iops",
      "fio": {
        "rw": "randread",
        "bs": "4k",
        "iodepth": 32,
        "numjobs": 1,
        "runtime": 60,
        "time_based": true
      },
      "target": {
        "value": 200,
        "unit": "KIOPS",
        "tolerance": 0.95
      }
    },
    {
      "name": "t_performance_random_read_sustained_006",
      "description": "随机读 IOPS (Sustained)",
      "type": "iops",
      "fio": {
        "rw": "randread",
        "bs": "4k",
        "iodepth": 32,
        "numjobs": 1,
        "runtime": 300,
        "time_based": true
      },
      "target": {
        "value": 105,
        "unit": "KIOPS",
        "tolerance": 0.95
      }
    },
    {
      "name": "t_performance_random_write_burst_007",
      "description": "随机写 IOPS (Burst)",
      "type": "iops",
      "fio": {
        "rw": "randwrite",
        "bs": "4k",
        "iodepth": 32,
        "numjobs": 1,
        "runtime": 60,
        "time_based": true
      },
      "target": {
        "value": 330,
        "unit": "KIOPS",
        "tolerance": 0.95
      }
    },
    {
      "name": "t_performance_random_write_sustained_008",
