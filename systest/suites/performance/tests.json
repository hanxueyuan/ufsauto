    {
      "name": "t_performance_mixed_rw_009",
      "description": "混合读写性能",
      "type": "iops",
      "fio": {
        "rw": "rw",
        "rwmixread": 70,
        "bs": "4k",
        "iodepth": 16,
        "numjobs": 1,
        "runtime": 60,
        "time_based": true
      },
      "target": {
        "value": 150,
        "unit": "KIOPS",
        "tolerance": 0.95
