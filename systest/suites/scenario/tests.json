{
  "description": "场景测试套件 - 真实应用场景验证",
  "tests": [
    {
      "name": "t_scenario_SensorWrite_001",
      "description": "传感器数据写入",
      "type": "scenario",
      "purpose": "模拟智驾系统传感器数据持续写入场景，验证 UFS 设备在多路传感器并发写入时的性能表现，确保满足≥400 MB/s 的持续写入带宽要求。",
      "precondition": {
        "system_env": {
          "os": "Debian 12, kernel 5.15.120",
          "cpu_memory": "8 核，16GB",
          "fio_version": "fio-3.33"
        },
        "device_info": {
          "path": "/dev/ufs0",
          "model": "UFS 3.1 128GB",
          "firmware": "v1.0.0",
          "capacity": "128GB",
          "available_space": "≥5GB"
        },
        "config": {
          "enable": [],
          "disable": [],
          "special": []
        },
        "lun_config": {
          "count": 4,
          "LUN0": "64GB 系统盘",
          "LUN1": "32GB 数据盘（测试目标）",
          "LUN2": "16GB 日志盘",
          "LUN3": "16GB 预留",
          "mapping": "LUN1→/dev/ufs0"
        },
        "health": {
          "smart": "正常",
          "remaining_life": "98%",
          "bad_blocks": 0,
          "temperature": "35℃（当前）/ 45℃（最高）",
          "error_count": "CRC 错误=0, 重传次数=0"
        },
        "verification": [
          "SMART 状态必须为正常",
          "可用空间必须≥5GB",
          "温度必须<70℃",
          "剩余寿命必须>90%"
        ]
      },
      "test_steps": [
        "模拟 8 路摄像头传感器并发写入",
        "配置参数：rw=write, bs=64k, iodepth=8, numjobs=8, rate=50M, runtime=300",
        "8 个线程并发写入 300 秒（5 分钟）",
        "监控总写入带宽",
        "检查是否有丢包或写入失败"
      ],
      "postcondition": [
        "记录总写入带宽",
        "检查丢包率（应为 0%）",
        "生成场景测试报告",
        "清理测试数据"
      ],
      "fio": {
        "rw": "write",
        "bs": "64k",
        "iodepth": 8,
        "numjobs": 8,
        "rate": "50M",
        "runtime": 300,
        "time_based": true
      },
      "target": {
        "total_bandwidth": 400,
        "latency_p99": 1000,
        "packet_loss": 0,
        "unit": "MB/s"
      },
      "acceptance_criteria": [
        "总写入带宽 ≥ 400 MB/s（8 × 50MB/s）",
        "丢包率 = 0%",
        "延迟 p99 < 1,000 μs",
        "无写入错误"
      ],
      "notes": [
        "模拟真实智驾场景，8 路传感器并发",
        "每路传感器 50MB/s，总计 400MB/s",
        "限速是为了模拟真实传感器，不是测试峰值性能",
        "如果带宽不足，检查 CPU 负载和 IO 调度策略"
      ]
    },
    {
      "name": "t_scenario_ModelLoad_002",
      "description": "算法模型加载",
      "type": "scenario",
      "purpose": "模拟 AI 模型加载和推理场景，验证 UFS 设备在大文件顺序读取和随机读取混合负载下的性能表现，确保满足≥1500 MB/s 的读取带宽要求。",
      "precondition": {
        "system_env": {
          "os": "Debian 12, kernel 5.15.120",
          "cpu_memory": "8 核，16GB",
          "fio_version": "fio-3.33"
        },
        "device_info": {
          "path": "/dev/ufs0",
          "model": "UFS 3.1 128GB",
          "firmware": "v1.0.0",
          "capacity": "128GB",
          "available_space": "≥10GB"
        },
        "config": {
          "enable": ["TURBO Mode"],
          "disable": ["省电模式"],
          "special": []
        },
        "lun_config": {
          "count": 4,
          "LUN0": "64GB 系统盘",
          "LUN1": "32GB 数据盘（测试目标）",
          "LUN2": "16GB 日志盘",
          "LUN3": "16GB 预留",
          "mapping": "LUN1→/dev/ufs0"
        },
        "health": {
          "smart": "正常",
          "remaining_life": "98%",
          "bad_blocks": 0,
          "temperature": "35℃（当前）/ 45℃（最高）",
          "error_count": "CRC 错误=0, 重传次数=0"
        },
        "verification": [
          "SMART 状态必须为正常",
          "可用空间必须≥10GB",
          "温度必须<70℃",
          "剩余寿命必须>90%"
        ]
      },
      "test_steps": [
        "模拟 AI 模型加载和推理并发场景",
        "配置参数：rw=randrw, rwmixread=70, bs=128k, iodepth=16, numjobs=4, runtime=300",
        "4 个并发线程持续运行 300 秒（5 分钟）",
        "监控读取带宽和加载时间",
        "收集测试结果"
      ],
      "postcondition": [
        "记录读取带宽",
        "记录模型加载时间",
        "生成场景测试报告",
        "清理测试数据"
      ],
      "fio": {
        "rw": "randrw",
        "rwmixread": 70,
        "bs": "128k",
        "iodepth": 16,
        "numjobs": 4,
        "runtime": 300,
        "time_based": true
      },
      "target": {
        "read_bandwidth": 1500,
        "load_time": 5,
        "unit": "MB/s"
      },
      "acceptance_criteria": [
        "读取带宽 ≥ 1500 MB/s",
        "模型加载时间 < 5 秒"
      ],
      "notes": [
        "模拟 AI 模型权重加载 + 推理并发场景",
        "70% 读 30% 写模拟真实推理负载",
        "128K 块大小模拟模型文件读取",
        "如果带宽不足，检查队列深度和并发数"
      ]
    }
  ]
}
