#!/usr/bin/env python3
"""
SysTest - UFS 系统测试框架
统一测试入口，参数化执行，自动报告，失效分析
"""

import argparse
import json
import os
import sys
from pathlib import Path

# 添加核心模块路径
script_dir = Path(__file__).parent.absolute()
core_dir = script_dir.parent / 'core'
sys.path.insert(0, str(core_dir))

from analyzer import FailureAnalyzer
from collector import ResultCollector
from reporter import ReportGenerator
from runner import TestRunner

__version__ = '1.0.0'


def main():
    parser = argparse.ArgumentParser(
        prog='SysTest',
        description='UFS 系统测试框架 - 统一测试入口',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog='''
示例:
  SysTest run -s performance -d /dev/ufs0     执行性能测试套件
  SysTest run -t seq_read_burst -v            执行单个测试 (详细输出)
  SysTest list                                 列出所有可用测试
  SysTest report --latest                      查看最新报告
  SysTest analyze --id=20260315_001           失效分析
'''
    )
    
    parser.add_argument('--version', '-V', action='version', version=f'SysTest {__version__}')
    
    subparsers = parser.add_subparsers(dest='command', help='可用命令')
    
    # ========== run 命令 ==========
    run_parser = subparsers.add_parser('run', help='执行测试')
    run_parser.add_argument('--test', '-t', help='单个测试项名称')
    run_parser.add_argument('--suite', '-s', help='测试套件名称')
    run_parser.add_argument('--device', '-d', default='/dev/ufs0', help='测试设备路径 (默认：/dev/ufs0)')
    run_parser.add_argument('--output', '-o', default='./results', help='输出目录 (默认：./results)')
    run_parser.add_argument('--format', '-f', nargs='+', default=['html'], choices=['html', 'json'], help='报告格式 (默认：html)')
    run_parser.add_argument('--config', '-c', help='配置文件路径')
    run_parser.add_argument('--verbose', '-v', action='store_true', help='详细输出')
    run_parser.add_argument('--background', '-b', action='store_true', help='后台执行')
    run_parser.add_argument('--id', help='测试 ID (默认自动生成)')
    run_parser.add_argument('--mode', '-m', choices=['development', 'production'], help='运行模式 (默认：development)')
    
    # ========== list 命令 ==========
    list_parser = subparsers.add_parser('list', help='列出可用测试')
    list_parser.add_argument('--suite', '-s', default='all', help='套件名称 (默认：all)')
    
    # ========== report 命令 ==========
    report_parser = subparsers.add_parser('report', help='生成/查看报告')
    report_parser.add_argument('--id', help='测试 ID')
    report_parser.add_argument('--latest', '-l', action='store_true', help='最新测试')
    report_parser.add_argument('--output', '-o', help='输出目录')
    report_parser.add_argument('--format', '-f', nargs='+', default=['html'], choices=['html', 'json', 'text'])
    
    # ========== analyze 命令 ==========
    analyze_parser = subparsers.add_parser('analyze', help='失效分析')
    analyze_parser.add_argument('--id', required=True, help='测试 ID')
    analyze_parser.add_argument('--output', '-o', help='分析报告输出路径')
    
    # ========== config 命令 ==========
    config_parser = subparsers.add_parser('config', help='配置管理')
    config_parser.add_argument('--show', action='store_true', help='显示当前配置')
    config_parser.add_argument('--init', action='store_true', help='初始化默认配置')
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        sys.exit(1)
    
    # ========== 执行命令 ==========
    if args.command == 'run':
        cmd_run(args)
    elif args.command == 'list':
        cmd_list(args)
    elif args.command == 'report':
        cmd_report(args)
    elif args.command == 'analyze':
        cmd_analyze(args)
    elif args.command == 'config':
        cmd_config(args)


def cmd_run(args):
    """执行测试"""
    print(f"🚀 SysTest v{__version__}")
    print("=" * 60)
    
    # 确定配置文件
    if args.config:
        config_file = args.config
    elif args.mode == 'production':
        config_file = 'config/production.json'
    else:
        config_file = 'config/development.json'
    
    # 确定运行模式
    mode = args.mode if args.mode else 'development'
    
    if args.verbose:
        print(f"使用配置文件：{config_file}")
        print(f"运行模式：{mode}")
    
    # 创建运行器
    runner = TestRunner(
        device=args.device,
        output_dir=args.output,
        config_file=config_file,
        verbose=args.verbose,
        mode=mode
    )
    
    # 生成测试 ID
    test_id = args.id or generate_test_id()
    print(f"📋 测试 ID: {test_id}")
    print(f"💾 设备：{args.device}")
    print(f"📁 输出：{args.output}")
    print("=" * 60)
    
    # 执行测试
    try:
        if args.test:
            print(f"▶️  执行测试项：{args.test}")
            results = runner.run_test(args.test, test_id)
        elif args.suite:
            print(f"▶️  执行测试套件：{args.suite}")
            results = runner.run_suite(args.suite, test_id)
        else:
            print("❌ 错误：请指定 --test 或 --suite")
            sys.exit(1)
        
        # 收集结果
        collector = ResultCollector()
        collected = collector.collect(results, test_id, args.device)
        
        # 生成报告
        reporter = ReportGenerator(output_dir=args.output, formats=args.format)
        report_path = reporter.generate(collected, test_id)
        
        print("=" * 60)
        print(f"✅ 测试完成!")
        print(f"📊 报告：{report_path}")
        
        # 显示摘要
        print_summary(collected)
        
    except KeyboardInterrupt:
        print("\n⚠️  测试被用户中断")
        sys.exit(130)
    except Exception as e:
        print(f"\n❌ 测试失败：{e}")
        if args.verbose:
            import traceback
            traceback.print_exc()
        sys.exit(1)


def cmd_list(args):
    """列出可用测试"""
    print(f"📋 SysTest v{__version__} - 可用测试")
    print("=" * 60)
    
    runner = TestRunner()
    suites = runner.list_suites()
    
    for suite_name, tests in suites.items():
        if args.suite != 'all' and suite_name != args.suite:
            continue
        
        print(f"\n📦 套件：{suite_name}")
        print("-" * 40)
        for test in tests:
            print(f"   • {test['name']}")
            print(f"     {test.get('description', '')}")
    
    print("\n" + "=" * 60)
    print("使用：SysTest run -s <suite> 或 SysTest run -t <test>")


def cmd_report(args):
    """生成/查看报告"""
    print(f"📊 SysTest v{__version__} - 报告生成")
    print("=" * 60)
    
    # 找到测试 ID
    if args.latest:
        test_id = find_latest_test_id(args.output or './results')
        if not test_id:
            print("❌ 未找到测试结果")
            sys.exit(1)
        print(f"📋 最新测试：{test_id}")
    elif args.id:
        test_id = args.id
    else:
        print("❌ 错误：请指定 --id 或 --latest")
        sys.exit(1)
    
    # 加载结果
    results_path = Path(args.output or './results') / test_id / 'results.json'
    if not results_path.exists():
        print(f"❌ 未找到测试结果：{results_path}")
        sys.exit(1)
    
    with open(results_path, 'r') as f:
        results = json.load(f)
    
    # 生成报告
    reporter = ReportGenerator(output_dir=args.output or './results', formats=args.format)
    report_path = reporter.generate(results, test_id)
    
    print(f"📄 报告已生成：{report_path}")


def cmd_analyze(args):
    """失效分析"""
    print(f"🔍 SysTest v{__version__} - 失效分析")
    print("=" * 60)
    
    # 使用指定的输出目录或默认目录
    output_dir = Path(args.output) if args.output else Path('./results')
    
    # 加载结果
    results_path = output_dir / args.id / 'results.json'
    if not results_path.exists():
        print(f"❌ 未找到测试结果：{results_path}")
        sys.exit(1)
    
    with open(results_path, 'r') as f:
        results = json.load(f)
    
    # 执行分析
    analyzer = FailureAnalyzer()
    analysis = analyzer.analyze(results)
    
    # 输出分析报告
    print_failure_analysis(analysis)
    
    # 保存分析报告
    if args.output:
        output_dir = Path(args.output)
        if output_dir.is_dir():
            # 如果是目录，在该目录下创建 analysis.md
            output_path = output_dir / args.id / 'analysis.md'
        else:
            # 如果是文件路径，直接使用
            output_path = output_dir
    else:
        output_path = Path('./results') / args.id / 'analysis.md'
    
    output_path.parent.mkdir(parents=True, exist_ok=True)
    with open(output_path, 'w', encoding='utf-8') as f:
        f.write(format_analysis_markdown(analysis))
    
    print(f"\n📄 分析报告：{output_path}")


def cmd_config(args):
    """配置管理"""
    config_dir = Path('./config')
    config_dir.mkdir(parents=True, exist_ok=True)
    
    if args.show:
        config = load_config()
        print("📋 当前配置:")
        print(json.dumps(config, indent=2))
    
    elif args.init:
        default_config = get_default_config()
        config_path = config_dir / 'default.json'
        
        with open(config_path, 'w', encoding='utf-8') as f:
            json.dump(default_config, f, indent=2)
        
        print(f"✅ 默认配置已创建：{config_path}")
    
    else:
        print("使用 --show 查看配置，--init 初始化默认配置")


# ========== 辅助函数 ==========

def load_config(config_path=None):
    """加载配置文件"""
    if config_path:
        path = Path(config_path)
    else:
        path = Path('./config/default.json')
    
    if path.exists():
        with open(path, 'r', encoding='utf-8') as f:
            return json.load(f)
    
    return get_default_config()


def get_default_config():
    """获取默认配置"""
    return {
        "device": {
            "default_path": "/dev/ufs0",
            "timeout": 300
        },
        "execution": {
            "default_runtime": 60,
            "sustained_runtime": 300,
            "retry_count": 3,
            "parallel_jobs": 1
        },
        "output": {
            "base_dir": "./results",
            "formats": ["html", "json"],
            "keep_logs": True,
            "keep_raw_data": True
        },
        "targets": {
            "seq_read_burst": 2100,
            "seq_read_sustained": 1800,
            "seq_write_burst": 1650,
            "seq_write_sustained": 250,
            "rand_read_burst": 200,
            "rand_read_sustained": 105,
            "rand_write_burst": 330,
            "rand_write_sustained": 60
        }
    }


def generate_test_id():
    """生成测试 ID"""
    from datetime import datetime
    now = datetime.now()
    return now.strftime('%Y%m%d_%H%M%S')


def find_latest_test_id(output_dir):
    """查找最新的测试 ID"""
    output_path = Path(output_dir)
    if not output_path.exists():
        return None
    
    test_dirs = [d for d in output_path.iterdir() if d.is_dir() and d.name.startswith('20')]
    if not test_dirs:
        return None
    
    return sorted(test_dirs, key=lambda x: x.name, reverse=True)[0].name


def print_summary(results):
    """打印测试摘要"""
    summary = results.get('summary', {})
    
    print(f"\n📊 测试摘要:")
    print(f"   总计：{summary.get('total', 0)} 项")
    print(f"   ✅ 通过：{summary.get('passed', 0)} 项")
    print(f"   ❌ 失败：{summary.get('failed', 0)} 项")
    print(f"   通过率：{summary.get('pass_rate', 0):.1f}%")


def print_failure_analysis(analysis):
    """打印失效分析结果"""
    print(f"\n🔍 失效分析结果:")
    print("=" * 60)
    
    root_causes = analysis.get('root_causes', [])
    
    if not root_causes:
        print("✅ 未检测到失效")
        return
    
    for i, cause in enumerate(root_causes, 1):
        confidence = cause.get('confidence', 0) * 100
        icon = "🔴" if confidence >= 70 else "🟡" if confidence >= 50 else "🔵"
        
        print(f"\n{icon} {i}. {cause.get('name', cause.get('type', 'Unknown'))}")
        print(f"   置信度：{confidence:.0f}%")
        print(f"   证据数：{cause.get('evidence_count', 0)}")
        
        print("   证据:")
        for evidence in cause.get('evidence', [])[:3]:
            print(f"     • {evidence}")
        
        print("   建议:")
        for suggestion in cause.get('suggestions', [])[:2]:
            print(f"     • {suggestion}")


def format_analysis_markdown(analysis):
    """格式化分析报告为 Markdown"""
    lines = ["# 失效分析报告\n"]
    
    root_causes = analysis.get('root_causes', [])
    
    if not root_causes:
        lines.append("✅ 未检测到失效\n")
        return '\n'.join(lines)
    
    lines.append("## 根因分析\n")
    lines.append("| 根因 | 置信度 | 证据数 |")
    lines.append("|------|--------|--------|")
    
    for cause in root_causes:
        name = cause.get('name', cause.get('type', 'Unknown'))
        confidence = f"{cause.get('confidence', 0) * 100:.0f}%"
        evidence_count = cause.get('evidence_count', 0)
        lines.append(f"| {name} | {confidence} | {evidence_count} |")
    
    lines.append("\n## 详细分析\n")
    
    for i, cause in enumerate(root_causes, 1):
        lines.append(f"### {i}. {cause.get('name', cause.get('type', 'Unknown'))}\n")
        lines.append(f"**置信度**: {cause.get('confidence', 0) * 100:.0f}%\n")
        
        lines.append("**证据**:\n")
        for evidence in cause.get('evidence', []):
            lines.append(f"- {evidence}")
        
        lines.append("\n**建议措施**:\n")
        for suggestion in cause.get('suggestions', []):
            lines.append(f"1. {suggestion}")
        
        lines.append("")
    
    return '\n'.join(lines)


if __name__ == '__main__':
    main()
