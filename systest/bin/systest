#!/usr/bin/env python3
"""
SysTest - UFS 系统测试框架
统一测试入口，参数化执行，自动报告，失效分析

架构：
    bin/systest (本文件) → core/runner.py → tests/t_*.py
    Runner 自动扫描 tests/ 目录下的脚本，通过 subprocess 调用执行。

使用示例：
    # 列出所有测试
    python3 bin/systest list

    # 执行性能测试套件
    python3 bin/systest run -s perf -d /dev/ufs0

    # 执行单个测试
    python3 bin/systest run -t t_perf_SeqReadBurst_001 -v

    # 查看最新报告
    python3 bin/systest report --latest

    # 失效分析
    python3 bin/systest analyze --id=20260319_001
"""

import argparse
import json
import os
import sys
from datetime import datetime
from pathlib import Path

# 添加核心模块路径
script_dir = Path(__file__).parent.absolute()
core_dir = script_dir.parent / "core"
sys.path.insert(0, str(core_dir))

from runner import TestRunner

__version__ = "2.0.0"


def main():
    parser = argparse.ArgumentParser(
        prog="SysTest",
        description="UFS 系统测试框架 - 统一测试入口",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  SysTest run -s perf -d /dev/ufs0              执行性能测试套件
  SysTest run -t t_perf_SeqReadBurst_001 -v     执行单个测试
  SysTest run -s all                             执行所有测试
  SysTest list                                    列出所有可用测试
  SysTest list -s perf                            列出性能测试
  SysTest report --latest                         查看最新报告
  SysTest analyze --id=20260319_001              失效分析
""",
    )

    parser.add_argument("--version", "-V", action="version", version=f"SysTest {__version__}")

    subparsers = parser.add_subparsers(dest="command", help="可用命令")

    # ========== run 命令 ==========
    run_parser = subparsers.add_parser("run", help="执行测试")
    run_parser.add_argument("--test", "-t", help="单个测试项名称 (如 t_perf_SeqReadBurst_001)")
    run_parser.add_argument("--suite", "-s", help="测试套件 (perf/func/rel/scen/qos/all)")
    run_parser.add_argument("--device", "-d", default="/dev/ufs0", help="测试设备路径 (默认：/dev/ufs0)")
    run_parser.add_argument("--output", "-o", default="./results", help="输出目录 (默认：./results)")
    run_parser.add_argument("--format", "-f", nargs="+", default=["json"], choices=["html", "json"], help="报告格式")
    run_parser.add_argument("--config", "-c", help="配置文件路径")
    run_parser.add_argument("--verbose", "-v", action="store_true", help="详细输出")
    run_parser.add_argument("--id", help="测试 ID (默认自动生成)")
    run_parser.add_argument("--mode", "-m", choices=["development", "production"], default="development", help="运行模式")

    # ========== list 命令 ==========
    list_parser = subparsers.add_parser("list", help="列出可用测试")
    list_parser.add_argument("--suite", "-s", default="all", help="套件名称 (perf/func/rel/scen/qos/all)")

    # ========== report 命令 ==========
    report_parser = subparsers.add_parser("report", help="生成/查看报告")
    report_parser.add_argument("--id", help="测试 ID")
    report_parser.add_argument("--latest", "-l", action="store_true", help="最新测试")
    report_parser.add_argument("--output", "-o", help="输出目录")
    report_parser.add_argument("--format", "-f", nargs="+", default=["html"], choices=["html", "json", "text"])

    # ========== analyze 命令 ==========
    analyze_parser = subparsers.add_parser("analyze", help="失效分析")
    analyze_parser.add_argument("--id", required=True, help="测试 ID")
    analyze_parser.add_argument("--output", "-o", help="分析报告输出路径")

    # ========== config 命令 ==========
    config_parser = subparsers.add_parser("config", help="配置管理")
    config_parser.add_argument("--show", action="store_true", help="显示当前配置")
    config_parser.add_argument("--init", action="store_true", help="初始化默认配置")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    if args.command == "run":
        cmd_run(args)
    elif args.command == "list":
        cmd_list(args)
    elif args.command == "report":
        cmd_report(args)
    elif args.command == "analyze":
        cmd_analyze(args)
    elif args.command == "config":
        cmd_config(args)


# ============================================================
# 命令实现
# ============================================================


def cmd_run(args):
    """执行测试"""
    print(f"🚀 SysTest v{__version__}")
    print("=" * 60)

    # 确定配置文件
    config_file = None
    if args.config:
        config_file = args.config
    elif args.mode == "production":
        config_file = "config/production.json"
    else:
        config_file = "config/development.json"

    # 创建 Runner
    runner = TestRunner(
        device=args.device,
        output_dir=args.output,
        config_file=config_file,
        verbose=args.verbose,
        mode=args.mode,
    )

    # 生成测试 ID
    test_id = args.id or datetime.now().strftime("%Y%m%d_%H%M%S")
    print(f"📋 测试 ID: {test_id}")
    print(f"💾 设备：{args.device}")
    print(f"📁 输出：{args.output}")
    print(f"🔧 模式：{args.mode}")
    print("=" * 60)

    try:
        if args.test:
            # 执行单个测试
            results = runner.run_test(args.test, test_id)
        elif args.suite:
            # 执行测试套件
            results = runner.run_suite(args.suite, test_id)
        else:
            print("❌ 错误：请指定 --test 或 --suite")
            sys.exit(1)

        # 保存结果到 JSON
        results_dir = Path(args.output) / test_id
        results_dir.mkdir(parents=True, exist_ok=True)
        results_file = results_dir / "results.json"

        with open(results_file, "w", encoding="utf-8") as f:
            json.dump(results, f, indent=2, ensure_ascii=False, default=str)

        print("=" * 60)
        print(f"✅ 测试完成!")
        print(f"📊 结果：{results_file}")

        # 打印摘要
        if "summary" in results:
            s = results["summary"]
            print(f"\n📊 摘要: {s['passed']}/{s['total']} 通过 ({s['pass_rate']}%)")
        elif "status" in results:
            print(f"\n📊 结果: {results['status']}")

        # 生成 HTML 报告 (如需要)
        if "html" in args.format:
            try:
                from reporter import ReportGenerator

                reporter = ReportGenerator(output_dir=args.output, formats=args.format)
                report_path = reporter.generate(results, test_id)
                print(f"📄 HTML 报告：{report_path}")
            except Exception as e:
                if args.verbose:
                    print(f"⚠️  HTML 报告生成失���：{e}")

    except KeyboardInterrupt:
        print("\n⚠️  测试被用户中断")
        sys.exit(130)
    except Exception as e:
        print(f"\n❌ 测试失败：{e}")
        if args.verbose:
            import traceback

            traceback.print_exc()
        sys.exit(1)


def cmd_list(args):
    """列出可用测试"""
    print(f"📋 SysTest v{__version__} - 可用测试")
    print("=" * 60)

    runner = TestRunner(verbose=False)
    suites = runner.list_suites()

    if not suites:
        print("⚠️  未找到测试脚本")
        print(f"   请检查目录：{runner.tests_dir}")
        sys.exit(1)

    total_count = 0

    for suite_name, tests in sorted(suites.items()):
        if args.suite != "all" and suite_name != args.suite:
            # 也支持全称匹配
            from runner import SUITE_PREFIX_MAP

            if SUITE_PREFIX_MAP.get(args.suite) != suite_name:
                continue

        print(f"\n📦 套件：{suite_name} ({len(tests)} 个)")
        print("-" * 40)
        for test in tests:
            desc = f"  {test['description']}" if test.get("description") else ""
            print(f"   • {test['name']}{desc}")
            total_count += 1

    print(f"\n{'=' * 60}")
    print(f"📊 共 {len(suites)} 个套件，{total_count} 个测试")
    print(f"\n使用方式：")
    print(f"   python3 bin/systest run -s <suite>       执行套件")
    print(f"   python3 bin/systest run -t <test_name>   执行单个测试")


def cmd_report(args):
    """生成/查看报告"""
    print(f"📊 SysTest v{__version__} - 报告")
    print("=" * 60)

    output_dir = Path(args.output or "./results")

    if args.latest:
        test_id = _find_latest_test_id(output_dir)
        if not test_id:
            print("❌ 未找到测试结果")
            sys.exit(1)
        print(f"📋 最新测试：{test_id}")
    elif args.id:
        test_id = args.id
    else:
        print("❌ 错误：请指定 --id 或 --latest")
        sys.exit(1)

    results_path = output_dir / test_id / "results.json"
    if not results_path.exists():
        print(f"❌ 未找到测试结果：{results_path}")
        sys.exit(1)

    with open(results_path, "r", encoding="utf-8") as f:
        results = json.load(f)

    # 打印结果摘要
    if "summary" in results:
        s = results["summary"]
        print(f"\n📊 摘要: {s['passed']}/{s['total']} 通过 ({s['pass_rate']}%)")

    if "test_cases" in results:
        for tc in results["test_cases"]:
            icon = "✅" if tc.get("status") == "PASS" else "❌"
            name = tc.get("test_name", "unknown")
            duration = tc.get("duration", 0)
            print(f"   {icon} {name} ({duration}s)")

    # 生成 HTML 报告
    if "html" in args.format:
        try:
            from reporter import ReportGenerator

            reporter = ReportGenerator(output_dir=str(output_dir), formats=args.format)
            report_path = reporter.generate(results, test_id)
            print(f"\n📄 报告：{report_path}")
        except Exception as e:
            print(f"⚠️  报告生成失败：{e}")


def cmd_analyze(args):
    """失效分析"""
    print(f"🔍 SysTest v{__version__} - 失效分析")
    print("=" * 60)

    output_dir = Path(args.output) if args.output else Path("./results")
    results_path = output_dir / args.id / "results.json"

    if not results_path.exists():
        print(f"❌ 未找到测试结果：{results_path}")
        sys.exit(1)

    with open(results_path, "r", encoding="utf-8") as f:
        results = json.load(f)

    try:
        from analyzer import FailureAnalyzer

        analyzer = FailureAnalyzer()
        analysis = analyzer.analyze(results)
        _print_failure_analysis(analysis)
    except ImportError:
        print("⚠️  失效分析模块不可用")


def cmd_config(args):
    """配置管理"""
    config_dir = Path("./config")
    config_dir.mkdir(parents=True, exist_ok=True)

    if args.show:
        # 显示配置 + 当前扫描到的测试
        config = _load_config()
        print("📋 当前配置:")
        print(json.dumps(config, indent=2, ensure_ascii=False))

        print("\n📦 当前测试脚本:")
        runner = TestRunner(verbose=False)
        suites = runner.list_suites()
        for suite_name, tests in sorted(suites.items()):
            print(f"   {suite_name}: {len(tests)} 个")

    elif args.init:
        default_config = _get_default_config()
        config_path = config_dir / "default.json"
        with open(config_path, "w", encoding="utf-8") as f:
            json.dump(default_config, f, indent=2, ensure_ascii=False)
        print(f"✅ 默认配置已创建：{config_path}")

    else:
        print("使用 --show 查看配置，--init 初始化默认配置")


# ============================================================
# 辅助函数
# ============================================================


def _load_config(config_path=None):
    """加载配置文件"""
    paths = [
        Path(config_path) if config_path else None,
        Path("./config/default.json"),
        Path("./config/development.json"),
    ]

    for p in paths:
        if p and p.exists():
            with open(p, "r", encoding="utf-8") as f:
                return json.load(f)

    return _get_default_config()


def _get_default_config():
    """获取默认配置"""
    return {
        "device": {"default_path": "/dev/ufs0", "timeout": 300},
        "execution": {
            "default_runtime": 60,
            "sustained_runtime": 300,
            "loop_count": 1,
            "retry_count": 1,
        },
        "output": {"base_dir": "./results", "formats": ["json"], "keep_logs": True},
    }


def _find_latest_test_id(output_dir):
    """查找最新的测试 ID"""
    output_path = Path(output_dir)
    if not output_path.exists():
        return None

    test_dirs = [d for d in output_path.iterdir() if d.is_dir() and d.name.startswith("20")]
    if not test_dirs:
        return None

    return sorted(test_dirs, key=lambda x: x.name, reverse=True)[0].name


def _print_failure_analysis(analysis):
    """打印失效分析结果"""
    root_causes = analysis.get("root_causes", [])

    if not root_causes:
        print("✅ 未检测到失效")
        return

    for i, cause in enumerate(root_causes, 1):
        confidence = cause.get("confidence", 0) * 100
        icon = "🔴" if confidence >= 70 else "🟡" if confidence >= 50 else "🔵"

        print(f"\n{icon} {i}. {cause.get('name', cause.get('type', 'Unknown'))}")
        print(f"   置信度：{confidence:.0f}%")

        for evidence in cause.get("evidence", [])[:3]:
            print(f"     • {evidence}")

        for suggestion in cause.get("suggestions", [])[:2]:
            print(f"     → {suggestion}")


if __name__ == "__main__":
    main()
