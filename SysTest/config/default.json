{
  "device": {
    "default_path": "/dev/ufs0",
    "timeout": 300
  },
  "execution": {
    "default_runtime": 60,
    "sustained_runtime": 300,
    "retry_count": 3,
    "parallel_jobs": 1
  },
  "output": {
    "base_dir": "./results",
    "formats": ["html", "json"],
    "keep_logs": true,
    "keep_raw_data": true
  },
  "report": {
    "template": "default",
    "include_charts": true,
    "include_raw_data": false,
    "auto_open": true
  },
  "targets": {
    "seq_read_burst": 2100,
    "seq_read_sustained": 1800,
    "seq_write_burst": 1650,
    "seq_write_sustained": 250,
    "rand_read_burst": 200,
    "rand_read_sustained": 105,
    "rand_write_burst": 330,
    "rand_write_sustained": 60
  }
}
